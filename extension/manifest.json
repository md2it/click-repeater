{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Click Repeater",
  "description": "__MSG_extDescription__",
  "version": "1.2.2",
  "background": {
    "service_worker": "sw.js",
    "scripts": [
      "lib/our/api.js",
      "lib/our/safe-extension-api.js",
      "app/safe-extension-api-rules.js",
      "lib/our/page-operability/probe.js",
      "lib/our/page-operability/content-probe.js",
      "lib/our/page-operability/can-operate.js",
      "lib/our/page-operability/messages.js",
      "lib/our/page-operability/show-notice.js",
      "app/page-operability/constants.js",
      "app/page-operability/notice.js",
      "app/execution-notice/constants.js",
      "app/execution-notice/notice.js",
      "app/background/state.js",
      "app/background/storage.js",
      "lib/our/support-survey/logic.js",
      "app/support-survey/constants.js",
      "app/support-survey/state.js",
      "app/background/execution.js",
      "app/background/badge.js",
      "app/background/check.js",
      "app/background/messages.js"
    ]
  },
  "action": {
    "default_title": "Click Repeater",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "contextMenus"
  ],
  "commands": {
    "clicks-prefix": {
      "description": "__MSG_commandRunDefaultClick__"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/icons/lucide/icons.js",
        "lib/our/api.js",
        "lib/our/page-operability/probe.js",
        "lib/our/page-operability/content-probe.js",
        "app/content/selectors.js",
        "app/content/state.js",
        "app/content/tracker.js",
        "app/content/editable.js",
        "app/content/keyboard.js",
        "app/content/mouse.js",
        "app/content/listeners.js",
        "app/content/sound.js",
        "app/content/check-overlay.js",
        "app/content/runner.js",
        "app/content/main.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "contact@md2it.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
